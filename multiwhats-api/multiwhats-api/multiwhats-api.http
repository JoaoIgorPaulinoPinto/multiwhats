@host = http://localhost:51563
# Cole o token gerado aqui para ser usado em todas as requisições automaticamente
@token = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..kDM-D31sc6Aj2Q8qqBasAjaz69AU1OA8XzpWoVALJ6Y

### Registrar Usuário
POST {{host}}/api/auth/register
Content-Type: application/json

{
  "name": "Joao Igor",
  "password": "123123"
}

### Login
# @name login
POST {{host}}/api/auth/login
Content-Type: application/json

{
  "name": "Joao Igor",
  "password": "123123"
}

### Logout
POST {{host}}/api/auth/logout
Authorization: Bearer {{token}}

### ==================== CLIENTS ====================

### Criar Cliente
POST {{host}}/api/clients
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Rosangela LTDA",
  "mainPhoneNumber": "222286065975335"
}

### Listar Clientes
GET {{host}}/api/clients
Authorization: Bearer {{token}}

### Buscar Cliente por ID
GET {{host}}/api/clients/1
Authorization: Bearer {{token}}

### Atualizar Cliente
PUT {{host}}/api/clients/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Timontec Atualizada",
  "mainPhoneNumber": "5515888888888",
  "status": "Active"  
}

### Deletar Cliente
DELETE {{host}}/api/clients/1
Authorization: Bearer {{token}}

### Contatos do Cliente
GET {{host}}/api/clients/1/contacts
Authorization: Bearer {{token}}

### ==================== CONTACTS ====================

### Criar Contato
POST {{host}}/api/contacts
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "jid": "5515987654321@c.us",
  "phoneNumber": "5515987654321",
  "name": "Maria Silva",
  "pushName": "Maria"
}

### Listar Contatos
GET {{host}}/api/contacts
Authorization: Bearer {{token}}

### Buscar Contato por ID
GET {{host}}/api/contacts/7
Authorization: Bearer {{token}}

### Atualizar Contato
PUT {{host}}/api/contacts/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "name": "Maria Souza",
  "pushName": "Maria",
  "isBlocked": false
}

### Deletar Contato
DELETE {{host}}/api/contacts/1
Authorization: Bearer {{token}}

### Atribuir Contato ao Cliente
PATCH {{host}}/api/contacts/1/assign
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "clientId": 1
}

### Desatrelar Contato do Cliente
PATCH {{host}}/api/contacts/1/unassign
Authorization: Bearer {{token}}

### Mensagens do Contato
GET {{host}}/api/contacts/1/messages
Authorization: Bearer {{token}}

### ==================== MESSAGES ====================

### Listar Mensagens
GET {{host}}/api/messages
Authorization: Bearer {{token}}

### Buscar Mensagem por ID
GET {{host}}/api/messages/1
Authorization: Bearer {{token}}

### Mensagens por Contato
GET {{host}}/api/messages/contact/7
Authorization: Bearer {{token}}

### Mensagens por Número de Telefone
GET {{host}}/api/messages/phone/5515996880359
Authorization: Bearer {{token}}

### Enviar Mensagem
POST {{host}}/api/messages/send
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "phoneNumber": "5515996880359",
  "text": "O multi-whats está funcionando!!"
}

### ==================== OCCURRENCES ====================

### Criar Ocorrência (chamado do número)
POST {{host}}/api/occurrences
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "title": "Problema com boleto",
  "description": "Cliente não recebeu o boleto por email",
  "priority": "High",
  "contactId": 1
}

### Listar Ocorrências
GET {{host}}/api/occurrences
Authorization: Bearer {{token}}

### Buscar Ocorrência por ID
GET {{host}}/api/occurrences/1
Authorization: Bearer {{token}}

### Atualizar Ocorrência
PUT {{host}}/api/occurrences/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "title": "Problema com boleto - resolvido",
  "description": "Cliente recebeu o boleto",
  "status": "Resolved",
  "priority": "Medium"
}

### Deletar Ocorrência
DELETE {{host}}/api/occurrences/1
Authorization: Bearer {{token}}

### ==================== TASKS ====================

### Criar Tarefa (demanda da empresa)
POST {{host}}/api/tasks
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "title": "Modificar relatório de custos diários",
  "description": "Empresa Timontec precisa de ajustes no relatório",
  "priority": "Medium",
  "clientId": 1
}

### Listar Tarefas
GET {{host}}/api/tasks
Authorization: Bearer {{token}}

### Buscar Tarefa por ID
GET {{host}}/api/tasks/1
Authorization: Bearer {{token}}

### Atualizar Tarefa
PUT {{host}}/api/tasks/1
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "title": "Modificar relatório de custos diários - revisado",
  "description": "Escopo alterado",
  "priority": "High",
  "dueDate": "2026-08-01T00:00:00Z"
}

### Atualizar Status da Tarefa (só Admin/Dev)
PATCH {{host}}/api/tasks/1/status
Content-Type: application/json
Authorization: Bearer {{token}}

{
  "status": "InProgress"
}

### Deletar Tarefa
DELETE {{host}}/api/tasks/1
Authorization: Bearer {{token}}

### ==================== WEBHOOK ====================

### Webhook - Receber Mensagem
POST {{host}}/api/webhook/whatsapp
Content-Type: application/json

{
  "from": "5515987654321@c.us",
  "phoneNumber": "5515987654321",
  "body": "Olá, tudo bem?",
  "timestamp": 1712345678,
  "notifyName": "Maria Silva",
  "messageType": "text",
  "hasMedia": false,
  "messageId": "true_abc123",
  "isForwarded": false,
  "userId": 1
}