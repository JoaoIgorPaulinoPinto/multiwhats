@multiwhats_api_HostAddress = http://localhost:51562

###

# @name login
POST {{multiwhats_api_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "nome": "Joao Igor",
  "senha": "123123"
}
#######################################################
### AUTENTICAÇÃO
#######################################################

### Registrar Usuário
POST {{multiwhats_api_HostAddress}}/api/auth/register
Content-Type: application/json

{
  "nome": "Joao Igor",
  "senha": "123123"
}

###

# @name login
POST {{multiwhats_api_HostAddress}}/api/Auth/login
Content-Type: application/json

{
  "nome": "Joao Igor",
  "senha": "123123"
}

###

### Logout
POST {{multiwhats_api_HostAddress}}/api/auth/logout
Authorization: Bearer {{login.response.body.token}}

#######################################################
### CONTATOS
#######################################################

###

### Criar Contato
# @name criarContato
POST {{multiwhats_api_HostAddress}}/criar
Content-Type: application/json
Authorization: Bearer {{login.response.body.token}}

{
  "nome": "Maria Silva",
  "numero": "5515987654321",
  "grupoId": null,
  "ocorrenciaAtualId": null
}

###

### Listar Contatos
GET {{multiwhats_api_HostAddress}}/pegar/todos
Authorization: Bearer {{login.response.body.token}}

###

### Buscar Contato por ID
GET {{multiwhats_api_HostAddress}}/pegar/1
Authorization: Bearer {{login.response.body.token}}

###

### Deletar Contato
DELETE {{multiwhats_api_HostAddress}}/delete/1
Authorization: Bearer {{login.response.body.token}}

#######################################################
### WHATSAPP
#######################################################

###

### Enviar Mensagem (ASP.NET -> Node -> WhatsApp)
POST {{multiwhats_api_HostAddress}}/send
Content-Type: application/json
Authorization: Bearer {{login.response.body.token}}

{
  "numero": "5515996880359",
  "conteudo": "O MultiWhats está funcionando! 🚀"
}

#######################################################
### WEBHOOK
#######################################################

###

### Simular mensagem recebida do WhatsApp
POST {{multiwhats_api_HostAddress}}/api/webhook/whatsapp
Content-Type: application/json

{
  "from": "5515996880359",
  "body": "Olá! Esta é uma mensagem de teste.",
  "timestamp": 1712345678,
  "notifyName": "Maria Silva"
}